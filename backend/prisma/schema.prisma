generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  passwordHash  String
  role          Role
  status        AccountStatus @default(PENDING)
  emailVerifiedAt            DateTime?
  emailVerificationTokenHash String?
  emailVerificationExpiresAt DateTime?
  pendingEmail               String?
  statusReason String?
  suspendedAt  DateTime?
  passwordResetTokenHash     String?
  passwordResetTokenExpiresAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // RELATIONS
  clientProfile     ClientProfile?
  restaurantProfile RestaurantProfile?
  livreurProfile    LivreurProfile?

  clientOrders      Order[] @relation("ClientOrders")
  restaurantOrders  Order[] @relation("RestaurantOrders")
  livreurOrders     Order[] @relation("LivreurOrders")

  offers            Offer[] @relation("RestaurantOffers")

  reviewsGiven      Review[] @relation("Reviewer")
  restaurantReviews Review[] @relation("RestaurantReview")
  delivererReviews  Review[] @relation("DelivererReview")

  complaintsGiven       Complaint[] @relation("Complainant")
  restaurantComplaints  Complaint[] @relation("RestaurantComplaint")
  delivererComplaints   Complaint[] @relation("DelivererComplaint")

  accountHistory AccountHistory[]
  legalAgreements LegalAgreement[]

  @@index([role])
  @@index([status])
}
model ClientProfile {
  id          String @id @default(cuid())
  userId      String @unique
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  fullName       String?
  phone          String?
  defaultAddress String?

  cuisinePreferences CuisinePreference[]
  notificationPreferences Json @default("{}")

  locationConsentGiven Boolean @default(false)
  locationConsentGivenAt DateTime?

  lastLatitude  Float?
  lastLongitude Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}                    
model RestaurantProfile {
  id       String @id @default(cuid())
  userId   String @unique
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  restaurantName    String?
  establishmentType EstablishmentType?
  phone             String?
  address           String?
  city              String?

  latitude  Float?
  longitude Float?

  logoUrl      String?
  coverImageUrl String?

  legalEntityName String?
  registrationNumberRNE String?
  ownershipType OwnershipType?

  businessRegistrationDocumentUrl String?
  hygieneCertificateUrl String?
  proofOfOwnershipOrLeaseUrl String?

  payoutMethod PayoutMethod?
  payoutDetails Json?

  avgRating Float @default(0)

  submittedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LegalAgreement {
  id         String   @id @default(cuid())
  userId     String
  type       String
  content    String
  acceptedAt DateTime @default(now())
  signerName String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AccountHistory {
  id        String        @id @default(cuid())
  userId    String
  actorId   String
  actorRole String
  action    AccountAction
  field     String?
  oldValue  String?
  newValue  String?
  reason    String?
  createdAt DateTime      @default(now())
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LivreurProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  fullName   String?
  phone      String?
  vehicleType String?
  zone        String?

  photoUrl String?

  cinOrPassportNumber String?

  licensePhotoUrl String?
  vehiclePhotoUrl  String?
  vehicleOwnershipDocUrl String?

  payoutMethod PayoutMethod?
  payoutDetails Json?

  avgRating Float @default(0)

  locationConsentGiven Boolean @default(false)
  lastLatitude  Float?
  lastLongitude Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model Order {
  id        String @id @default(uuid())

  orderCode String
  reference String @unique

  offerId String
  offer   Offer @relation(fields: [offerId], references: [id])

  clientId String
  client   User @relation("ClientOrders", fields: [clientId], references: [id])

  restaurantId String
  restaurant   User @relation("RestaurantOrders", fields: [restaurantId], references: [id])

  livreurId String?
  livreur   User? @relation("LivreurOrders", fields: [livreurId], references: [id])

  items Json
  total Float

  status OrderStatus @default(PENDING)

  collectionMethod CollectionMethod?
  deliveryAddress  String?
  deliveryPhone    String?
  deliveryFee      Float?

  paymentMethod PaymentMethod?
  paymentDetails Json?

  clientLocation    String?
  delivererLocation String?

  // QR SYSTEM (pickup safety)
  pickupQrTokenHash String?
  pickupQrExpiresAt DateTime?
  pickupQrUsedAt    DateTime?
  pickupQrStatus    QrStatus @default(NOT_SCANNED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reviews    Review[]
  complaints Complaint[]
}

model Offer {
  id             String @id @default(cuid())
  restaurantId   String
  restaurant     User   @relation("RestaurantOffers", fields: [restaurantId], references: [id], onDelete: Restrict)

  description    String
  originalPrice  Float
  discountedPrice Float
  quantity       Int

  photoUrl String

  pickupTime     String
  pickupDateTime DateTime

  categories String[] @default([])

  visibility OfferVisibility @default(IDENTIFIED)
  deliveryAvailable Boolean @default(false)

  status OfferStatus @default(ACTIVE)

  orders Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([restaurantId])
  @@index([status])
}

model Review {
  id String @id @default(cuid())

  orderId String?
  order   Order? @relation(fields: [orderId], references: [id])

  reviewerId String
  reviewer   User @relation("Reviewer", fields: [reviewerId], references: [id])

  restaurantId String?
  restaurant   User? @relation("RestaurantReview", fields: [restaurantId], references: [id])

  delivererId String?
  deliverer   User? @relation("DelivererReview", fields: [delivererId], references: [id])

  rating Int
  comment String

  createdAt DateTime @default(now())
}

model Complaint {
  id String @id @default(cuid())

  orderId String?
  order   Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  complainantId String
  complainant   User @relation("Complainant", fields: [complainantId], references: [id], onDelete: Cascade)

  restaurantId String?
  restaurant   User? @relation("RestaurantComplaint", fields: [restaurantId], references: [id])

  delivererId String?
  deliverer   User? @relation("DelivererComplaint", fields: [delivererId], references: [id])

  reason String
  description String?

  createdAt DateTime @default(now())
}

model LegalAgreement {
  id String @id @default(cuid())
  userId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  type String
  content String
  signerName String

  acceptedAt DateTime @default(now())
}
model AccountHistory {
  id String @id @default(cuid())

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  actorId String
  actorRole String

  action AccountAction
  field String?
  oldValue String?
  newValue String?
  reason String?

  createdAt DateTime @default(now())
}

enum Role {
  CLIENT
  LIVREUR
  RESTAURANT
  ADMIN
}

enum AccountStatus {
  PENDING
  APPROVED
  REJECTED
  CHANGES_REQUIRED
  SUSPENDED
  UNSUSPEND
  PROFILE_EDIT
}

enum OrderStatus {
  PENDING
  CONFIRMED
  ASSIGNED
  READY
  PICKED_UP
  DELIVERED
  CANCELLED
  EXPIRED
}

enum PaymentMethod {
  CARD
  D17
  PAYPAL
}

enum CollectionMethod {
  PICKUP
  DELIVERY
}

enum QrStatus {
  NOT_SCANNED
  SCANNED
  USED
  EXPIRED
}